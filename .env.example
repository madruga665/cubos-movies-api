# Configurações de Banco de Dados (Prisma)
# Exemplo local: postgresql://johndoe:mypassword@localhost:5432/mydb?schema=public
DATABASE_URL="postgresql://user:password@localhost:5432/cubos_movies_db?schema=public"

# Configurações do Better Auth
# Gere um segredo forte com: openssl rand -base64 32
BETTER_AUTH_SECRET="seu_segredo_de_autenticacao_aqui"
# URL base da sua API (onde o Better Auth está rodando)
BETTER_AUTH_URL="http://localhost:5000"

# Configurações de CORS e Integração
# URL do seu front-end que irá consumir esta API
FRONTEND_URL="http://localhost:3000"

# Configurações de Logging (Loki)
# URL do seu serviço Loki (ex: http://localhost:3100)
LOKI_BASE_URL="http://localhost:3100"

# Porta do Servidor (Opcional, padrão 5000)
PORT=5000

# Docker Compose (Utilizado apenas para o ambiente local)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=cubos_movies_db
